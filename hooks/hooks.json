{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/block_no_verify.py\""
          }
        ],
        "description": "Block git --no-verify flag to protect pre-commit hooks from being bypassed",
        "id": "pre:bash:block-no-verify"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/commit_quality.py\""
          }
        ],
        "description": "Pre-commit quality: validate commit message format (Conventional Commits), detect console.log/debugger/secrets",
        "id": "pre:bash:commit-quality"
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/read_before_edit.py\""
          }
        ],
        "description": "Warn when editing a file that hasn't been read in current session (advisory, non-blocking)",
        "id": "pre:edit:read-before-edit"
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/doc_file_warning.py\""
          }
        ],
        "description": "Warn about creating non-standard documentation files outside recognized paths",
        "id": "pre:write:doc-file-warning"
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/config_protection.py\""
          }
        ],
        "description": "Warn when modifying linter/formatter config files — steer toward fixing code instead of weakening configs",
        "id": "pre:edit:config-protection"
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/prompt_injection_scan.py\""
          }
        ],
        "description": "Scan for prompt injection patterns in files being written (advisory, non-blocking)",
        "id": "pre:write:prompt-injection-scan"
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/state_file_lock.py\""
          }
        ],
        "description": "STATE.md file lock guard — prevent parallel write conflicts during wave execution",
        "id": "pre:write:state-file-lock"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/command_audit_log.py\""
          }
        ],
        "description": "Audit log all bash commands with timestamps for session review",
        "id": "post:bash:command-audit-log"
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/console_log_warn.py\"",
            "timeout": 5
          }
        ],
        "description": "Warn about console.log/print statements left in edited files",
        "id": "post:edit:console-log-warn"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/git_push_reminder.py\""
          }
        ],
        "description": "Remind to review changes before git push",
        "id": "post:bash:git-push-reminder"
      }
    ],
    "Notification": [
      {
        "matcher": "StatusLine",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/statusline.py\"",
            "timeout": 3
          }
        ],
        "description": "StatusLine: model + current task + directory + context usage percentage with progress bar",
        "id": "notification:statusline"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/session_summary.py\"",
            "async": true,
            "timeout": 10
          }
        ],
        "description": "Persist session activity summary (files edited, commands run, skills invoked)",
        "id": "stop:session-summary"
      }
    ]
  }
}
