#!/usr/bin/env python3
"""
opc-tools — SuperOPC CLI utility for workflow operations.

Usage: python opc-tools <command> [args] [--raw] [--cwd <dir>]

Centralizes: config parsing, state management, phase lookup,
verification, template filling, and compound init commands.

See `python opc-tools help` for full command listing.
"""

from __future__ import annotations

import sys
from pathlib import Path

# Ensure scripts/ is on sys.path so cli/ package is importable
_SCRIPT_DIR = Path(__file__).resolve().parent.parent / "scripts"
if str(_SCRIPT_DIR) not in sys.path:
    sys.path.insert(0, str(_SCRIPT_DIR))

from cli.router import main

if __name__ == "__main__":
    main()
