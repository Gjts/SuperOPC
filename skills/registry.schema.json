{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/gjts/superopc/skills/registry.schema.json",
  "title": "SuperOPC Skill Registry",
  "description": "Structured index of all skills. Generated by scripts/build_skill_registry.py from SKILL.md frontmatter. See ADR-0001 for rationale.",
  "type": "object",
  "required": ["$schema", "version", "skills"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Schema marker (free-form string identifying the registry)"
    },
    "version": {
      "type": "string",
      "description": "Registry schema version, e.g. 2.0.0-draft",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.-]+)?$"
    },
    "description": {
      "type": "string"
    },
    "generated_at": {
      "type": "string",
      "description": "ISO-8601 timestamp when registry was generated"
    },
    "skills": {
      "type": "array",
      "description": "List of all skill entries. Must be non-empty.",
      "minItems": 1,
      "items": {"$ref": "#/definitions/skill"}
    }
  },
  "additionalProperties": false,
  "definitions": {
    "skill": {
      "type": "object",
      "required": ["id", "name", "path", "type", "version"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique skill identifier (kebab-case).",
          "pattern": "^[a-z][a-z0-9-]*$"
        },
        "name": {
          "type": "string",
          "description": "Human-readable skill name (matches SKILL.md frontmatter.name)."
        },
        "path": {
          "type": "string",
          "description": "Repo-relative path to the SKILL.md file.",
          "pattern": "^skills/.*SKILL\\.md$"
        },
        "type": {
          "type": "string",
          "description": "Skill category. Drives routing and default priority.",
          "enum": ["dispatcher", "atomic", "meta", "learning"]
        },
        "description": {
          "type": "string",
          "description": "One-line trigger description (copied from SKILL.md frontmatter)."
        },
        "triggers": {
          "type": "object",
          "description": "Structured triggers used by the Intent Router L1 layer.",
          "properties": {
            "keywords": {"type": "array", "items": {"type": "string"}},
            "phrases":  {"type": "array", "items": {"type": "string"}},
            "phases":   {"type": "array", "items": {"type": "string"}}
          },
          "additionalProperties": false
        },
        "tags": {
          "type": "array",
          "description": "Semantic tags used for coarse filtering before embedding lookup (Router L2).",
          "items": {"type": "string"}
        },
        "input_schema": {
          "type": "object",
          "description": "Optional input contract for the skill. Free-form key -> field spec.",
          "additionalProperties": true
        },
        "output_schema": {
          "type": "object",
          "description": "Optional output contract for the skill. Free-form key -> field spec.",
          "additionalProperties": true
        },
        "dispatches_to": {
          "type": ["string", "null"],
          "description": "For dispatcher skills, the id of the agent that owns the workflow. null for atomic/meta/learning skills."
        },
        "dependencies": {
          "type": "object",
          "description": "Declared downstream skills, atomic skills called, and referenced documents.",
          "properties": {
            "downstream": {"type": "array", "items": {"type": "string"}},
            "atomic":     {"type": "array", "items": {"type": "string"}},
            "references": {"type": "array", "items": {"type": "string"}}
          },
          "additionalProperties": false
        },
        "version": {
          "type": "string",
          "description": "Skill content version (semver).",
          "pattern": "^\\d+\\.\\d+\\.\\d+(-[a-zA-Z0-9.-]+)?$"
        },
        "deprecated": {
          "type": "boolean",
          "default": false
        },
        "usage_stats": {
          "type": "object",
          "description": "Observed usage metrics. Updated by scripts/hooks/observe.py.",
          "properties": {
            "last_30d_invocations": {"type": "integer", "minimum": 0},
            "success_rate":         {"type": ["number", "null"]},
            "avg_tokens_saved":     {"type": ["number", "null"]}
          },
          "additionalProperties": false
        },
        "embedding": {
          "type": ["array", "null"],
          "description": "Semantic embedding vector. null during Phase A (added by Phase B).",
          "items": {"type": "number"}
        },
        "priority": {
          "type": "integer",
          "description": "Tie-breaker for router candidates. Higher wins.",
          "minimum": 0,
          "maximum": 100
        }
      },
      "additionalProperties": false
    }
  }
}
