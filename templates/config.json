{
  "_comment": "SuperOPC 项目配置 — 由 /opc-init 生成，可手动编辑",

  "mode": "interactive",
  "granularity": "standard",
  "model_profile": "balanced",

  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "nyquist": false,
    "node_repair": true,
    "requirements_gate": true,
    "regression_gate": true,
    "schema_drift": true,
    "scope_guard": true,
    "claim_traceability": true,
    "code_review": true,
    "code_review_depth": "standard",
    "auto_advance": false,
    "discuss_mode": "discuss",
    "skip_discuss": false,
    "text_mode": false
  },

  "parallelization": {
    "enabled": true,
    "plan_level": true,
    "task_level": false,
    "max_concurrent_agents": 3,
    "min_plans_for_parallel": 2
  },

  "git": {
    "branching_strategy": "none",
    "commit_docs": true,
    "phase_branch_template": "opc/phase-{N}-{name}",
    "milestone_branch_template": "opc/{version}-{name}"
  },

  "gates": {
    "confirm_project": true,
    "confirm_roadmap": true,
    "confirm_plan": true,
    "confirm_transition": true,
    "issues_review": true
  },

  "safety": {
    "always_confirm_destructive": true,
    "always_confirm_external_services": true
  },

  "hooks": {
    "context_warnings": true,
    "state_file_lock": true
  },

  "project_code": null,
  "response_language": null,
  "agent_skills": {}
}
