{
  "_comment": "Mobile App 模板配置 — Kotlin + Jetpack Compose",

  "mode": "interactive",
  "granularity": "standard",
  "model_profile": "balanced",

  "workflow": {
    "research": false,
    "plan_check": true,
    "verifier": true,
    "nyquist": false,
    "node_repair": true,
    "requirements_gate": true,
    "regression_gate": true,
    "schema_drift": false,
    "scope_guard": true,
    "claim_traceability": false,
    "code_review": true,
    "code_review_depth": "standard",
    "auto_advance": false,
    "discuss_mode": "discuss",
    "skip_discuss": false,
    "text_mode": false
  },

  "parallelization": {
    "enabled": false,
    "plan_level": false,
    "task_level": false,
    "max_concurrent_agents": 1,
    "min_plans_for_parallel": 3
  },

  "git": {
    "branching_strategy": "phase",
    "commit_docs": true,
    "phase_branch_template": "feat/phase-{N}-{name}",
    "milestone_branch_template": "release/{version}"
  },

  "gates": {
    "confirm_project": true,
    "confirm_roadmap": true,
    "confirm_plan": true,
    "confirm_transition": true,
    "issues_review": true
  },

  "safety": {
    "always_confirm_destructive": true,
    "always_confirm_external_services": true
  },

  "hooks": {
    "context_warnings": true,
    "state_file_lock": true
  },

  "project_code": null,
  "response_language": null,
  "agent_skills": {
    "primary": ["kotlin-compose", "tdd"],
    "secondary": ["api-design", "security-review"]
  }
}
